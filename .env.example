# Configuración de PySap (ADR-0003). Copia a `.env` y rellena.
# El `.env` está en .gitignore: NUNCA lo subas al repo.

# --- Obligatorias ---
SAP_CONNECTION=PRD - Producción      # nombre de la entrada en SAP Logon
SAP_CLIENT=100                       # mandante
SAP_USER=MI_USUARIO
SAP_PASSWORD=mi_password

# --- Opcionales ---
SAP_LANG=ES                          # idioma de login (vacío = por defecto)
SAP_LOGON_PATH=C:\Program Files (x86)\SAP\FrontEnd\SAPgui\saplogon.exe
